# Aeolus configuration. Copy to .env and edit. Every value is optional and
# has a sensible default; the ones you almost certainly want to set are in the
# LOCATION block. Defaults describe an example location (Norman, OK).

# ---- Location ----------------------------------------------------------------
# LAT/LON is the forecast/radar point. Find yours at https://www.latlong.net
# or right-click "What's here?" in Google Maps.
LAT=35.22
LON=-97.44
# Shown in the app's location picker.
LOCATION_NAME=Home

# NWS zones drive severe-weather alerts and are US-only. Look yours up:
#   1. Go to https://forecast.weather.gov and enter your address.
#   2. The URL and page footer show your County (UGC like OKC027) and
#      Forecast Zone (UGC like OKZ029).
#   3. NWS_ZONE is the COUNTY code (alerts are polled by county).
#      NWS_UGC is the comma list of codes counted as "your area" for the
#      "affects you" badge (usually your county + forecast zone).
# Full table (county FIPS -> UGC + forecast zone): https://www.weather.gov/gis/ZoneCounty
NWS_ZONE=OKC027
NWS_UGC=OKC027,OKZ029

# NWS alerts + the IEM watchdog are US-only. Set 0 outside the US (or if you
# don't want severe-weather alerts). IMPORTANT: the default zone above is a real
# US county, so a non-US user must turn this OFF rather than leaving the zone
# set, or they would see that county's alerts. Forecast/nowcast/radar are
# unaffected either way.
ALERTS_ENABLED=1

# Local timezone (IANA name) for timestamps and quiet hours.
# List: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Chicago

# NWS asks API clients to send an identifying User-Agent with a real contact.
# Put your email or site here; it is only sent to weather.gov.
USER_AGENT=aeolus/1.0 (you@example.com)

# ---- Ports / storage ---------------------------------------------------------
# Host port the app is published on (container always listens on 8080).
PORT=8080
# Storage path. In the container this is forced to /data/aeolus.db; this value
# only matters when you run the app outside Docker.
DB_PATH=./data/aeolus.db

# ---- Optional integrations ---------------------------------------------------
# Pirate Weather secondary forecast source (free key at pirateweather.net).
# Empty = that poller stays off; Open-Meteo alone is fine.
PIRATE_WEATHER_KEY=

# Slack Incoming Webhook for alert notifications. Empty = alerts are logged as
# DRY-RUN instead of posted, so you can watch the logs before wiring Slack.
SLACK_WEBHOOK_URL=

# Tier-2 (watch/advisory) notifications queue into a morning digest during
# these local hours. Tier-1 warnings always bypass quiet hours.
QUIET_HOURS_START=22
QUIET_HOURS_END=7

# ---- Poll cadences (seconds) -------------------------------------------------
# Alert cadences are clamped to the NWS documented 30s floor; the rest to >=1s.
FORECAST_INTERVAL=3600
NOWCAST_INTERVAL=300
PIRATE_INTERVAL=3600
ALERTS_INTERVAL=60
# Cadence while a convective/tornado watch is active
ALERTS_INTERVAL_HOT=30
WATCHDOG_INTERVAL=60

# ---- HTTP / resilience -------------------------------------------------------
HTTP_TIMEOUT=15
# Forecast runs kept per source/kind for spread display and postmortems
FORECAST_KEEP_RUNS=5
# Failure backoff, seconds (doubles from base up to cap)
BACKOFF_BASE=30
BACKOFF_CAP=900
# Primary alert poller silent this long -> watchdog ops warning
POLLER_SILENCE_ALARM=300

# ---- Burn window (/v1/burn), mph and percent ---------------------------------
# "Can I light a brush pile?" verdict. no_burn beats caution; the combo rule is
# wind AND humidity crossing together. Tune to your fire policy or ignore it.
BURN_WIND_NO_BURN=15
BURN_GUSTS_NO_BURN=25
BURN_HUMIDITY_NO_BURN=25
BURN_COMBO_WIND=10
BURN_COMBO_HUMIDITY=35
BURN_WIND_CAUTION=10
BURN_GUSTS_CAUTION=20
BURN_HUMIDITY_CAUTION=40
# Hourly rows scanned for a verdict flip (changes_at)
BURN_LOOKAHEAD_HOURS=12
# Multi-day outlook: days served and the window each day covers from midnight
BURN_OUTLOOK_DAYS=7
BURN_OUTLOOK_WINDOW_HOURS=48

# ---- Radar -------------------------------------------------------------------
# US-only (IEM NEXRAD + NOAA nowCOAST). Loop depth in hours (~72 frames at 5-min).
RADAR_ENABLED=1
RADAR_LOOP_HOURS=6
# Storm-region extent west,south,east,north: the map bbox + fallback render box.
# Widen/shift this to your region; it should comfortably contain your LAT/LON.
RADAR_BBOX=-103.5,30.5,-91.5,39.5
# Zoom levels warm-fetched around your location per frame (comma lists, a-b ranges)
RADAR_WARM_ZOOMS=6-11
# Tile/frame disk cache; empty = "radar" next to the DB (/data/radar in container)
RADAR_CACHE_DIR=
# Cache size cap in MB; whole frames evicted oldest-first beyond it
RADAR_CACHE_MAX_MB=500
# IEM catalog poll cadence, seconds (clamped to a 30s floor)
RADAR_INTERVAL=90
# Protomaps basemap served at /basemap.pmtiles; empty = next to the DB.
# Optional: without it the radar map shows a notice but radar frames still work.
BASEMAP_PATH=

# Set to 0 to disable background pollers (serve-only process, e.g. for tests)
AEOLUS_POLLERS=1
